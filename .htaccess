# ============================================================
# 🔥 .HTACCESS - Shillong Teer Live Result
# ============================================================
# Performance, Security & SEO Optimization
# Last Updated: 2026-07-14
# ============================================================

# ============================================================
# 🔥 HTTPS Redirect (HTTP থেকে HTTPS-এ রিডাইরেক্ট)
# ============================================================
RewriteEngine On
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]

# ============================================================
# 🔥 WWW to Non-WWW Redirect
# ============================================================
RewriteCond %{HTTP_HOST} ^www\.(.*)$ [NC]
RewriteRule ^(.*)$ https://%1/$1 [R=301,L]

# ============================================================
# 🔥 Remove Trailing Slash (যদি ইউআরএলের শেষে / থাকে)
# ============================================================
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)/$ /$1 [R=301,L]

# ============================================================
# 🔥 Browser Caching (ব্রাউজার ক্যাশিং - অপটিমাইজড)
# ============================================================
<IfModule mod_expires.c>
  ExpiresActive On
  
  # HTML files - 1 hour
  ExpiresByType text/html "access plus 1 hour"
  
  # CSS & JavaScript - 1 month
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType text/javascript "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  
  # Images - 1 year
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/jpg "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/ico "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
  
  # Fonts - 1 year
  ExpiresByType font/woff "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  
  # PDF - 1 month
  ExpiresByType application/pdf "access plus 1 month"
</IfModule>

# ============================================================
# 🔥 GZIP Compression (ফাইল সাইজ কমিয়ে লোড স্পিড বাড়ানো)
# ============================================================
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/x-javascript application/json application/xml application/rss+xml
</IfModule>

# ============================================================
# 🔥 Security Headers (নিরাপত্তা বাড়ানো - আপডেটেড)
# ============================================================
<IfModule mod_headers.c>
  # Prevent MIME type sniffing
  Header set X-Content-Type-Options "nosniff"
  
  # Enable XSS protection
  Header set X-XSS-Protection "1; mode=block"
  
  # Prevent clickjacking
  Header set X-Frame-Options "SAMEORIGIN"
  
  # Referrer Policy
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  
  # HSTS (Force HTTPS) - 1 year
  Header set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
  
  # ✅ Cache-Control for dynamic content
  Header set Cache-Control "max-age=3600, public"
  
  # ✅ Remove Server info for security
  Header unset Server
  Header unset X-Powered-By
</IfModule>

# ============================================================
# 🔥 404 Error Page
# ============================================================
ErrorDocument 404 /404.html

# ============================================================
# 🔥 Prevent Directory Listing
# ============================================================
Options -Indexes

# ============================================================
# 🔥 Block Bad Bots & Scrapers (আপডেটেড)
# ============================================================
<IfModule mod_rewrite.c>
  RewriteCond %{HTTP_USER_AGENT} ^.*(ahrefs|SEMrush|MJ12bot|DotBot|BLEXBot|ia_archiver|ltx71|serpstatbot|MegaIndex|DataForSeoBot|SurdotlyBot|Pinterestbot|DuckDuckBot|YandexBot|YandexAccessibilityBot|YandexMobileBot|YandexDirectDyn|YandexScreenshotBot|YandexVideoParser|YandexImageResizer|GPTBot|CCBot|ClaudeBot|Bytespider).*$ [NC]
  RewriteRule .* - [F,L]
</IfModule>

# ============================================================
# 🔥 Cache-Control Headers (আপডেটেড)
# ============================================================
<IfModule mod_headers.c>
  # Static files - 1 year
  <FilesMatch "\.(ico|pdf|flv|jpg|jpeg|png|gif|js|css|swf|webp|woff|woff2)$">
    Header set Cache-Control "max-age=31536000, public"
  </FilesMatch>
  
  # HTML files - 1 hour
  <FilesMatch "\.(html|htm)$">
    Header set Cache-Control "max-age=3600, public"
  </FilesMatch>
  
  # ✅ No cache for dynamic files
  <FilesMatch "\.(php)$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
</IfModule>

# ============================================================
# 🔥 CORS Headers (Cross-Origin Resource Sharing)
# ============================================================
<IfModule mod_headers.c>
  # Allow cross-origin requests for fonts and images
  <FilesMatch "\.(ttf|ttc|otf|eot|woff|woff2|font.css|css|js|png|jpg|jpeg|gif|svg|webp)$">
    Header set Access-Control-Allow-Origin "*"
  </FilesMatch>
</IfModule>

# ============================================================
# 🔥 Redirect old URLs to new ones (SEO)
# ============================================================
# Redirect 301 /old-page.html /new-page.html

# ============================================================
# 🔥 Block access to sensitive files
# ============================================================
<FilesMatch "^(\.htaccess|\.htpasswd|\.env|\.git|\.gitignore|composer\.json|composer\.lock|package\.json|package-lock\.json|web\.config|php\.ini)$">
  Order Allow,Deny
  Deny from all
</FilesMatch>

# ============================================================
# 🔥 Prevent hotlinking (ইমেজ চুরি প্রতিরোধ)
# ============================================================
RewriteCond %{HTTP_REFERER} !^$
RewriteCond %{HTTP_REFERER} !^https?://(www\.)?shillongteerliveresult\.in/ [NC]
RewriteRule \.(jpg|jpeg|png|gif|svg|webp|mp4|pdf)$ - [F]

# ============================================================
# 🔥 Speed Optimization (স্পিড অপটিমাইজেশন)
# ============================================================

# Enable Keep-Alive
<IfModule mod_headers.c>
  Header set Connection keep-alive
</IfModule>

# ============================================================
# 🔥 PHP Settings (PHP সেটিংস)
# ============================================================
<IfModule mod_php7.c>
  php_value upload_max_filesize 10M
  php_value post_max_size 10M
  php_value max_execution_time 30
</IfModule>

# ============================================================
# 🔥 SSL Certificate Check (SSL সার্টিফিকেট চেক)
# ============================================================
<IfModule mod_rewrite.c>
  RewriteCond %{SERVER_PORT} 80
  RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]
</IfModule>
